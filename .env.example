# Copier ce fichier en .env et remplir les valeurs.
# Le .env contient des secrets et n'est PAS commite (voir .gitignore).

# --- Serveur ---
PORT=3000
NODE_ENV=development

# --- Base de donnees ---
# Option A : URL complete (prioritaire si definie)
# DATABASE_URL=mysql://user:pass@host:3306/dbname

# Option B : variables separees
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=levelup
DB_USER=root
DB_PASS=
MYSQL_SSL=false

# --- CORS (origines front autorisees, separees par virgules) ---
CORS_ORIGINS=http://localhost:3001

# --- JWT ---
# Generer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Doit faire au moins 32 caracteres (le serveur refuse de demarrer sinon).
JWT_SECRET=remplace_par_un_secret_de_128_caracteres_hexa
